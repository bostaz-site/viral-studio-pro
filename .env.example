# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (Whisper) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── ElevenLabs (phase 2 — TTS) ──────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_BASE_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_STUDIO=price_xxxxx

# ── Social Auth — TikTok ─────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ── Social Auth — Instagram ───────────────────────────────────────────────────
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here

# ── Social Auth — YouTube ─────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# ── Twitch API ────────────────────────────────────────────────────────────────
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# ── Security ──────────────────────────────────────────────────────────────────
ENCRYPTION_SECRET=generate_a_64_char_hex_string
CRON_SECRET=your_cron_secret_here

# ── VPS Rendering Server ─────────────────────────────────────────────────────
VPS_RENDER_URL=https://your-vps-ip:4000
VPS_RENDER_API_KEY=your_vps_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
# En production, remplace par ton URL Netlify ou domaine custom
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app
