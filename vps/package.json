{
  "name": "viral-studio-render-api",
  "version": "1.0.0",
  "description": "Express.js render API for Viral Studio Pro VPS",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pm2-start": "pm2 start ecosystem.config.js",
    "pm2-stop": "pm2 stop viral-studio-api",
    "pm2-restart": "pm2 restart viral-studio-api",
    "pm2-logs": "pm2 logs viral-studio-api"
  },
  "keywords": [
    "viral-studio",
    "ffmpeg",
    "video-rendering",
    "express"
  ],
  "author": "Viral Studio Team",
  "license": "ISC",
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0",
    "@supabase/supabase-js": "^2.43.4",
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
