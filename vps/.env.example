# Server
PORT=3100
NODE_ENV=production

# API Authentication
API_SECRET=your-super-secret-key-here-change-this-in-production

# Supabase Configuration
SUPABASE_URL=https://swlbdlgwqeinwxuviwgn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# File System Paths
# These directories must be writable and have enough disk space
TEMP_DIR=/opt/viral-studio/tmp
OUTPUT_DIR=/opt/viral-studio/output

# FFmpeg & System
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp
MAX_RENDER_TIME_SECONDS=300
MAX_FILE_SIZE_BYTES=2147483648

# Logging
LOG_LEVEL=info
